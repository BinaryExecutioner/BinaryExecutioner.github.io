---
import BaseLayout from "./BaseLayout.astro";

const { post } = Astro.props;
const { title, date, categories = [], tags = [], description } = post.data;
---

<BaseLayout title={`${title} | Binary Executioner`}>
  <article class="post">
    <header class="post-header">
      <p class="post-path">./posts/{post.slug}.md</p>

      <h1>{title}</h1>

      {description && <p class="post-description">{description}</p>}

      <div class="post-meta">
        <span>{date.toLocaleDateString("en-IN")}</span>
        {categories.length > 0 && <span>{categories.join(" / ")}</span>}
      </div>

      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => <span>#{tag}</span>)}
        </div>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>