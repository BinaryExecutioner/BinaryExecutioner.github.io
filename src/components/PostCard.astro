---
import { getWriteupSection, getWriteupSectionLabel } from "../utils/classifyPost";

const { post } = Astro.props;

const { title, date, tags = [], description } = post.data;

const slug = post.id.replace(/\.md$/, "");
const section = getWriteupSection(post);
const sectionLabel = getWriteupSectionLabel(section);

const summary =
  description ||
  "Writeup notes, enumeration, exploitation path, and lessons learned.";

const url = `/posts/${slug}/`;
---

<article class="post-card">
  <p class="post-path">./writeups/{section}/{slug}</p>

  <h3>
    <a href={url}>{title}</a>
  </h3>

  <p>{summary}</p>

  <div class="post-meta">
    <span>{date.toLocaleDateString("en-IN")}</span>
    <span>{sectionLabel}</span>
  </div>

  {tags.length > 0 && (
    <div class="tags">
      {tags.slice(0, 4).map((tag) => <span>#{tag}</span>)}
    </div>
  )}
</article>